shared-workspace-lockfile=true
enable-pre-post-scripts=true
hoist=false

# Workaround for Prefab 2.1.0 / Clikt bug splitting paths at '='
# See: https://github.com/google/prefab/issues/187
virtual-store-dir-max-length=80
strict-peer-dependencies=false
dedupe-peer-dependents=false
auto-install-peers=false
save-exact=true

public-hoist-pattern[]=@nx/*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*oxlint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/react
public-hoist-pattern[]=react-native
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=*@opentui*


