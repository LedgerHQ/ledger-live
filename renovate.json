{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":dependencyDashboard"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "automerge": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "GitHub Actions Internal (CI)",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["LedgerHQ/*", "ledgerhq/*"],
      "pinDigests": false,
      "labels": ["dependencies", "github_actions"],
      "reviewers": ["team:wallet-ci"],
      "assignees": ["team:wallet-ci"]
    },
    {
      "description": "GitHub Actions External (CI)",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "minimumReleaseAge": "15 days",
      "labels": ["dependencies", "github_actions"],
      "reviewers": ["team:wallet-ci"],
      "assignees": ["team:wallet-ci"],
      "matchPackageNames": ["!/^LedgerHQ/.*/", "!/^ledgerhq/.*/"]
    },
    {
      "description": "Lumen UI React - version updates",
      "matchPackageNames": ["@ledgerhq/lumen-ui-react"],
      "commitMessagePrefix": "chore(desktop):",
      "commitMessageTopic": "update {{depName}}",
      "commitMessageExtra": "to {{newVersion}}",
      "labels": ["dependencies", "ui", "lumen"],
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "prPriority": 10
    },
    {
      "description": "Lumen Design Core - Catalog updates",
      "matchPackageNames": ["@ledgerhq/lumen-design-core"],
      "commitMessagePrefix": "chore:",
      "commitMessageTopic": "update {{depName}} catalog",
      "commitMessageExtra": "to {{newVersion}}",
      "labels": ["dependencies", "ui", "lumen", "catalog"],
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "prPriority": 10
    },
    {
      "description": "Lumen UI RNative - version updates",
      "matchPackageNames": ["@ledgerhq/lumen-ui-rnative"],
      "commitMessagePrefix": "chore(mobile):",
      "commitMessageTopic": "update {{depName}}",
      "commitMessageExtra": "to {{newVersion}}",
      "labels": ["dependencies", "ui", "lumen"],
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "prPriority": 10
    },
    {
      "description": "Core Ownership Rules",
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "matchPackageNames": [
        "/changesets/",
        "/commitlint/",
        "/esbuild/",
        "/eslint/",
        "/prettier/",
        "/turbo/",
        "/typescript/",
        "/vite/",
        "/zx/"
      ],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Electron linked updates",
      "groupName": "electron",
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "matchPackageNames": [
        "/electron/",
        "/^@electron/",
        "!@sentry/electron",
        "!electron-context-menu",
        "!electron-store",
        "!vite-plugin-electron"
      ],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Metro linked updates",
      "matchPackageNames": [
        "metro",
        "metro-core",
        "metro-config",
        "metro-resolver",
        "metro-runtime",
        "metro-source-map",
        "metro-transform-worker"
      ],
      "groupName": "metro",
      "reviewers": ["team:live-hub"],
      "assignees": ["team:live-hub"],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Expo monorepo grouping",
      "extends": ["monorepo:expo"],
      "groupName": null
    },
    {
      "description": "Global npm minimum release age",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "E2E - version updates",
      "matchManagers": ["npm"],
      "matchFileNames": ["e2e/desktop/**", "e2e/mobile/**"],
      "commitMessagePrefix": "chore(e2e):",
      "labels": ["dependencies", "e2e"],
      "reviewers": ["team:qaa"],
      "assignees": ["team:qaa"]
    },
    {
      "description": "E2E - group major updates",
      "matchManagers": ["npm"],
      "matchFileNames": ["e2e/desktop/**", "e2e/mobile/**"],
      "matchUpdateTypes": ["major"],
      "groupName": "e2e major updates"
    }
  ],
  "prConcurrentLimit": 10,
  "separateMinorPatch": true,
  "timezone": "Europe/Paris",
  "enabledManagers": ["npm", "github-actions"]
}
