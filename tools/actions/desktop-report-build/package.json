{
  "name": "@actions/desktop-report-build",
  "version": "1.1.0",
  "description": "Report the results of desktop builds in a `summary.json` file",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "rslib build",
    "lint": "oxlint ./",
    "lint:fix": "oxlint ./ --fix --quiet",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "@actions/core": "1.10.1",
    "@actions/github": "6.0.0",
    "node-fetch": "3.3.2",
    "@rslib/core": "catalog:"
  }
}
