{
  "name": "@ledgerhq/device-intent",
  "version": "0.2.0",
  "description": "Ledger Device Intent types and helpers for the Device Intent Executor",
  "private": true,
  "license": "Apache-2.0",
  "keywords": [
    "Ledger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/device-intent",
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "prewatch": "pnpm build",
    "watch": "tsc --watch --project tsconfig.build.json",
    "watch:es": "tsc --watch --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "lint": "eslint ./src --no-error-on-unmatched-pattern --ext .ts,.tsx --cache",
    "lint:fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit --customConditions node",
    "test": "jest --passWithNoTests",
    "coverage": "jest --coverage"
  },
  "dependencies": {
    "@ledgerhq/logs": "workspace:^",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@ledgerhq/device-management-kit": "catalog:",
    "@ledgerhq/client-ids": "workspace:^",
    "@ledgerhq/types-devices": "workspace:^",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/jest": "catalog:",
    "@types/react": "catalog:",
    "@types/uuid": "^9.0.0",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "catalog:",
    "typescript": "catalog:",
    "xstate": "catalog:"
  },
  "peerDependencies": {
    "@ledgerhq/device-management-kit": "catalog:",
    "@ledgerhq/client-ids": "workspace:^",
    "@ledgerhq/types-devices": "workspace:^",
    "react": "catalog:",
    "rxjs": "catalog:",
    "xstate": "catalog:"
  },
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "import": "./lib-es/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./lib-es/*": "./lib-es/*.js",
    "./lib/*": "./lib/*.js",
    "./*": {
      "@ledgerhq/source": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "import": "./lib-es/*.js",
      "require": "./lib/*.js",
      "default": "./lib/*.js"
    },
    "./package.json": "./package.json"
  }
}
