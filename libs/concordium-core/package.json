{
  "name": "@ledgerhq/concordium-core",
  "version": "0.3.0",
  "description": "Shared Concordium protocol types, serialization, and utilities",
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "typecheck": "tsc --noEmit --customConditions node",
    "test": "jest",
    "coverage": "jest --coverage",
    "lint": "eslint ./src --no-error-on-unmatched-pattern --ext .ts --cache",
    "lint:fix": "pnpm lint --fix",
    "unimported": "unimported"
  },
  "dependencies": {
    "bs58check": "^3.0.1",
    "bip32-path": "^0.4.2"
  },
  "devDependencies": {
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "rimraf": "^4.4.1"
  },
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "require": "./lib/index.js",
      "default": "./lib-es/index.js"
    },
    "./lib-es/*": "./lib-es/*.js",
    "./lib/*": "./lib/*.js",
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "require": "./lib/*.js",
      "default": "./lib-es/*.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/concordium-core"
}
