{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "jsx": "react",
    "declaration": true,
    "declarationMap": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "lib": ["es2020", "dom"],
    "outDir": "lib-es",
    "rootDir": "src",
    "paths": { "*": ["./*"] },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "jest", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
