{
  "name": "@ledgerhq/live-dmk-ws-proxy-shared",
  "version": "0.1.0",
  "description": "Shared protocol types for DMK WebSocket proxy",
  "private": true,
  "license": "Apache-2.0",
  "keywords": [
    "Ledger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/live-dmk-ws-proxy-shared",
  "main": "./lib-es/index.js",
  "types": "./lib-es/index.d.ts",
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "require": "./lib-es/index.js",
      "default": "./lib-es/index.js"
    },
    "./lib-es/*": "./lib-es/*.js",
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "require": "./lib-es/*.js",
      "default": "./lib-es/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf lib-es",
    "build": "tsc --project tsconfig.build.json",
    "watch": "tsc --watch --project tsconfig.build.json",
    "watch:es": "pnpm watch",
    "lint": "eslint ./src --no-error-on-unmatched-pattern --ext .ts,.tsx --cache",
    "lint:fix": "pnpm lint --fix",
    "typecheck": "tsc --noEmit --customConditions node",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {},
  "devDependencies": {
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rxjs": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "rxjs": "catalog:"
  }
}
