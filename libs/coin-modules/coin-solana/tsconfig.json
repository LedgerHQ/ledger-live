{
  "extends": "../../../tsconfig.base",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "downlevelIteration": true,
    "lib": ["es2020", "dom"],
    "types": ["node", "jest"],
    "exactOptionalPropertyTypes": true,
    "outDir": "./lib",
    "rootDir": "src"
  },
  "include": ["src/**/*"]
}
