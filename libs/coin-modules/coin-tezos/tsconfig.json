{
  "extends": "../../../tsconfig.base",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "lib": [
      "es2022",
      "dom"
    ],
    "outDir": "lib",
    "rootDir": "src",
    "types": ["node", "jest"],
    "typeRoots": [
      "./node_modules/@types",
      "./types/@taquito"
    ]
  },
  "include": [
    "src/**/*",
    "types/**/*.d.ts"
  ]
}