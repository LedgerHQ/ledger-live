{
  "extends": "../../../tsconfig.base",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "downlevelIteration": true,
    "lib": ["es2022", "dom"],
    "types": ["node", "jest"],
    "rootDir": "./src",
    "exactOptionalPropertyTypes": true,
    "typeRoots": ["./node_modules/@types", "index.d.ts"],
    "outDir": "./lib"
  },
  "include": ["src/**/*", "index.d.ts"]
}
