{
  "extends": "../../../tsconfig.base",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": true,
    "downlevelIteration": true,
    "lib": [
      "es2022",
      "dom"
    ],
    "rootDir": "./src",
    "outDir": "lib",
    "exactOptionalPropertyTypes": true,
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*",
    "deviceTransactionConfig.ts",
    "transaction.ts"
  ]
}