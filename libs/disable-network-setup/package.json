{
  "name": "@ledgerhq/disable-network-setup",
  "version": "0.3.0",
  "private": true,
  "description": "Disable network hook, util for tests",
  "keywords": [
    "Ledger"
  ],
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsgo --project tsconfig.build.json && tsgo --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "unimported": "unimported",
    "test": "jest --passWithNoTests",
    "coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "axios": "catalog:",
    "jest": "catalog:",
    "nock": "14.0.3",
    "@swc/jest": "catalog:",
    "@swc/core": "catalog:",
    "ts-node": "10.9.2",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "import": "./lib-es/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./lib-es/*": "./lib-es/*.js",
    "./lib/*": "./lib/*.js",
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "import": "./lib-es/*.js",
      "require": "./lib/*.js",
      "default": "./lib/*.js"
    },
    "./package.json": "./package.json"
  }
}
