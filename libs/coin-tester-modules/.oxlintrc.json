{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es6": true
  },
  "plugins": ["eslint", "typescript", "jest"],
  "rules": {
    "typescript/no-empty-function": "off",
    "typescript/no-explicit-any": "warn"
  },
  "overrides": [
    {
      "files": ["src/**/*.test.{ts,tsx}", "src/*.test.{ts,tsx}"],
      "env": { "jest": true },
      "plugins": ["jest"]
    }
  ]
}
