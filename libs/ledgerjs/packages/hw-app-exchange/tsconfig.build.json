{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "customConditions": [],
    "types": [
      "node"
    ]
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/setupTests.ts",
