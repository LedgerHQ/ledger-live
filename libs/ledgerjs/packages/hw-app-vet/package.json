{
  "name": "@ledgerhq/hw-app-vet",
  "version": "0.11.1",
  "description": "Ledger Hardware Wallet VeChain Application API",
  "keywords": [
    "Hardware Wallet",
    "Ledger",
    "LedgerWallet",
    "NanoS",
    "VeChain",
    "VeThor",
    "vet",
    "vtho"
  ],
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/ledgerjs/packages/hw-app-vet",
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "main": "lib/Vet.js",
  "module": "lib-es/Vet.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "coverage": "jest --coverage --passWithNoTests",
    "prewatch": "pnpm build",
    "watch": "tsc --watch --project tsconfig.build.json",
    "watch:es": "tsc --watch --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "doc": "documentation readme src/** --section=API --pe ts --re ts --re d.ts",
    "lint": "oxlint ./src",
    "lint:fix": "pnpm lint --fix",
    "test": "jest"
  },
  "dependencies": {
    "@ledgerhq/cryptoassets": "workspace:^",
    "@ledgerhq/errors": "workspace:^",
    "@ledgerhq/hw-transport": "workspace:*",
    "@ledgerhq/hw-transport-mocker": "workspace:^",
    "@ledgerhq/logs": "workspace:^",
    "@vechain/sdk-core": "2.0.0"
  },
  "devDependencies": {
    "@ledgerhq/hw-transport-mocker": "workspace:^",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "documentation": "14.0.2",
    "jest": "catalog:",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.4.0"
  }
}
