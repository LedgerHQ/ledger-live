{
  "name": "@ledgerhq/cryptoassets",
  "version": "13.43.0",
  "description": "Ledger crypto-assets list",
  "keywords": [
    "Ledger"
  ],
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/ledgerjs/packages/cryptoassets",
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "typesVersions": {
    "*": {
      "*.json": [
        "*.json"
      ],
      "*": [
        "lib/*"
      ],
      "lib/*": [
        "lib/*"
      ],
      "lib-es/*": [
        "lib-es/*"
      ]
    }
  },
  "exports": {
    "./lib/*": "./lib/*.js",
    "./lib/*.js": "./lib/*.js",
    "./lib-es/*": "./lib-es/*.js",
    "./lib-es/*.js": "./lib-es/*.js",
    "./cal-client": {
      "@ledgerhq/source": "./src/cal-client/index.ts",
      "require": "./lib/cal-client/index.js",
      "default": "./lib-es/cal-client/index.js"
    },
    "./cal-client/test-helpers": {
      "@ledgerhq/source": "./src/cal-client/test-helpers.ts",
      "require": "./lib/cal-client/test-helpers.js",
      "default": "./lib-es/cal-client/test-helpers.js"
    },
    "./state": {
      "@ledgerhq/source": "./src/state.ts",
      "require": "./lib/state.js",
      "default": "./lib-es/state.js"
    },
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "require": "./lib/*.js",
      "default": "./lib-es/*.js"
    },
    "./*.js": {
      "@ledgerhq/source": "./src/*.ts",
      "require": "./lib/*.js",
      "default": "./lib-es/*.js"
    },
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "require": "./lib/index.js",
      "default": "./lib-es/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "prewatch": "pnpm build",
    "watch": "tsc --watch --project tsconfig.build.json",
    "watch:es": "tsc --watch --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "lint": "oxlint ./src",
    "lint:fix": "pnpm lint --fix",
    "test": "jest",
    "coverage": "jest --coverage",
    "unimported": "unimported",
    "test:importer": "jest ./src/crypto-assets-importer/",
    "import:cal-tokens": "ts-node ./src/crypto-assets-importer/index.ts"
  },
  "dependencies": {
    "@ledgerhq/errors": "workspace:^",
    "@ledgerhq/live-env": "workspace:^",
    "@ledgerhq/logs": "workspace:^",
    "@ledgerhq/types-live": "workspace:^",
    "@reduxjs/toolkit": "catalog:",
    "invariant": "2",
    "lodash": "^4.17.21",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ledgerhq/types-cryptoassets": "workspace:^",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-redux": "catalog:",
    "rimraf": "^4.4.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.7.0"
  }
}
