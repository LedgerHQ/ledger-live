{
  "name": "@ledgerhq/ethereum-provider",
  "version": "0.7.0",
  "private": true,
  "description": "Ledger Live ethereum provider",
  "keywords": [
    "Ledger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/ethereum-provider",
  "main": "lib/ethereum-provider.js",
  "module": "lib/ethereum-provider.mjs",
  "browser": "lib/ethereum-provider.umd.json",
  "types": "lib/index.d.ts",
  "license": "Apache-2.0",
  "dependencies": {
    "events": "^3.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@types/events": "^3.0.3",
    "@types/jest": "catalog:",
    "@types/uuid": "^9.0.8",
    "jest": "catalog:",
    "jest-environment-jsdom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  },
  "scripts": {
    "clean": "rimraf lib",
    "build": "pnpm run clean && rspack build -c rspack.config.mjs && tsc -p tsconfig.build.json --emitDeclarationOnly && node scripts/build-umd-json.mjs",
    "lint": "oxlint -c ../oxc-live-libs/.oxlintrc.json ./src",
    "lint:fix": "pnpm exec oxfmt -c ../../.oxfmtrc.json ./src && oxlint -c ../oxc-live-libs/.oxlintrc.json ./src --fix --quiet",
    "format": "pnpm exec oxfmt -c ../../.oxfmtrc.json ./src",
    "format:check": "pnpm exec oxfmt -c ../../.oxfmtrc.json ./src --check",
    "test": "jest",
    "typecheck": "tsc --noEmit --customConditions node",
    "unimported": "unimported"
  },
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "import": "./lib/ethereum-provider.mjs",
      "require": "./lib/ethereum-provider.js",
      "default": "./lib/ethereum-provider.js"
    },
    "./lib/ethereum-provider.umd.json": "./lib/ethereum-provider.umd.json",
    "./lib/*": "./lib/*.js",
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "import": "./lib/*.mjs",
      "require": "./lib/*.js",
      "default": "./lib/*.js"
    },
    "./package.json": "./package.json"
  }
}
