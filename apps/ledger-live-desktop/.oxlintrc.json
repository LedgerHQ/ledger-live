{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "globals": {
    "__DEV__": "readonly",
    "INDEX_URL": "readonly",
    "Atomics": "readonly",
    "SharedArrayBuffer": "readonly",
    "__SENTRY_URL__": "readonly",
    "__APP_VERSION__": "readonly",
    "__GIT_REVISION__": "readonly",
    "__PRERELEASE__": "readonly",
    "__CHANNEL__": "readonly",
    "__static": "readonly",
    "$": "readonly"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off"
  },
  "plugins": [
    "eslint",
    "import",
    "oxc",
    "unicorn",
    "typescript",
    "react",
    "jest"
  ],
  "ignorePatterns": [
    "*.min.js",
    "src/renderer/families/generated.ts",
    "src/mvvm/hooks/redux.ts"
  ],
  "rules": {
    "eslint/no-unused-vars": "warn",
    "eslint/no-empty-pattern": "warn",
    "eslint/no-constant-binary-expression": "warn",
    "react/no-did-mount-set-state": "warn",
    "unicorn/no-useless-fallback-in-spread": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/no-new-array": "off",
    "jest/no-conditional-expect": "warn",
    "jest/expect-expect": "warn",
    "jest/require-to-throw-message": "warn",
    "jest/valid-title": "warn",
    "jest/no-disabled-tests": "warn",
    "typescript/no-explicit-any": "error",
    "typescript/no-deprecated": "error",
    "import/no-duplicates": "error",
    "import/no-named-as-default": "off",
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          "lodash",
          {
            "name": "react-redux",
            "importNames": ["useSelector", "useDispatch", "useStore"],
            "message": "Import typed hooks from 'LLD/hooks/redux' instead of 'react-redux' to ensure proper TypeScript typing."
          }
        ],
        "patterns": [
          {
            "group": [
              "@ledgerhq/live-common/lib/**",
              "@ledgerhq/live-common/lib-es/**"
            ],
            "message": "Please remove the /lib import from live-common import."
          },
          {
            "group": [
              "~/mvvm/**"
            ],
            "message": "Use 'LLD' alias instead of '~/mvvm'. Replace '~/mvvm' with 'LLD' in your imports."
          },
          {
            "group": [
              "**/renderer/families/*/**",
              "~/renderer/families/*/**"
            ],
            "message": "families files must not be imported directly. use the bridge or export them through the LLDCoinFamily interface instead."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/renderer/families/**"],
      "rules": {
        "eslint/no-restricted-imports": "off"
      }
    },
    {
      "files": [
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.integration.ts",
        "**/*.integration.tsx"
      ],
      "env": {
        "jest": true
      },
      "plugins": [
        "jest"
      ],
      "rules": {
        "typescript/no-explicit-any": "warn"
      }
    }
  ]
}