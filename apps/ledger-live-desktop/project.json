{
  "name": "ledger-live-desktop",
  "targets": {
    "build": {
      "cache": true,
      "inputs": [
        "default",
        "^default",
        "desktopEnv",
        "sharedEnv",
        {
          "env": "RUNNER_OS"
        },
        {
          "env": "CI_OS"
        },
        {
          "runtime": "node -p \"process.platform + '-' + process.arch\""
        }
      ],
      "outputs": [
        "{projectRoot}/dist/**",
        "{projectRoot}/.webpack/**",
        "{projectRoot}/metafile.*.json",
        "{projectRoot}/lib/**",
        "{projectRoot}/lib-es/**",
        "{projectRoot}/build/**"
      ]
    },
    "build:testing": {
      "cache": false,
      "dependsOn": [
        "^build"
      ]
    },
    "build-lib-deps": {
      "executor": "nx:noop",
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    },
    "test": {
      "dependsOn": [
        "build:testing"
      ],
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    }
  }
}