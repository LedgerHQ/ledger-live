{
  "name": "ledger-live-desktop",
  "targets": {
    "build": {
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "desktopEnv",
        "sharedEnv"
      ]
    },
    "build:testing": {
      "cache": false,
      "dependsOn": [
        "^build"
      ]
    },
    "build-lib-deps": {
      "executor": "nx:noop",
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    },
    "test": {
      "dependsOn": [
        "build:testing"
      ],
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    }
  }
}