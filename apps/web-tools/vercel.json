{
  "framework": null,
  "installCommand": "pnpm i -F \"@ledgerhq/web-tools...\" -F \"ledger-live\"",
  "buildCommand": "cd ../.. && pnpm exec nx run @ledgerhq/web-tools:build",
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
