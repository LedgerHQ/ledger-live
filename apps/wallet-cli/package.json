{
  "name": "@ledgerhq/wallet-cli",
  "version": "1.0.1",
  "private": true,
  "description": "Ledger Wallet CLI using Device Management Kit (USB)",
  "license": "Apache-2.0",
  "bin": {
    "wallet-cli": "./bin/wallet-cli"
  },
  "files": [
    "bin/",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run ./src/cli.ts",
    "dev": "bunli dev",
    "generate": "bunli generate",
    "build": "bunli build",
    "prepare:npm": "node ./scripts/prepare-npm.mjs",
    "check:notices": "node ./scripts/check-third-party-notices.mjs",
    "pack:check": "node ./scripts/pack-check.mjs",
    "smoke:npm": "node ./scripts/smoke-npm.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/",
    "coverage": "bun test src/ --coverage",
    "lint": "oxlint src bunli.config.ts",
    "lint:ci": "oxlint src bunli.config.ts --quiet",
    "lint:fix": "oxfmt -c ../../.oxfmtrc.json src bunli.config.ts && oxlint src bunli.config.ts --fix --quiet",
    "format": "oxfmt -c ../../.oxfmtrc.json src bunli.config.ts",
    "format:check": "oxfmt -c ../../.oxfmtrc.json src bunli.config.ts --check"
  },
  "optionalDependencies": {
    "@ledgerhq/wallet-cli-darwin-arm64": "workspace:*",
    "@ledgerhq/wallet-cli-linux-arm64": "workspace:*",
    "@ledgerhq/wallet-cli-linux-x64": "workspace:*",
    "@ledgerhq/wallet-cli-windows-x64": "workspace:*"
  },
  "devDependencies": {
    "@bunli/core": "0.9.1",
    "@bunli/utils": "0.6.0",
    "@ledgerhq/coin-bitcoin": "workspace:^",
    "@ledgerhq/coin-evm": "workspace:^",
    "@ledgerhq/coin-module-framework": "catalog:",
    "@ledgerhq/coin-solana": "workspace:^",
    "@ledgerhq/cryptoassets": "workspace:^",
    "@ledgerhq/device-management-kit": "catalog:",
    "@ledgerhq/errors": "workspace:^",
    "@ledgerhq/hw-app-exchange": "workspace:^",
    "@ledgerhq/hw-transport": "workspace:*",
    "@ledgerhq/ledger-wallet-framework": "workspace:^",
    "@ledgerhq/live-common": "workspace:^",
    "@ledgerhq/live-config": "workspace:^",
    "@ledgerhq/live-dmk-shared": "workspace:^",
    "@ledgerhq/live-env": "workspace:^",
    "@ledgerhq/live-wallet": "workspace:^",
    "@ledgerhq/logs": "workspace:^",
    "@ledgerhq/types-cryptoassets": "workspace:^",
    "@ledgerhq/types-devices": "workspace:*",
    "@ledgerhq/types-live": "workspace:^",
    "@shared/schema-primitives": "workspace:^",
    "bignumber.js": "catalog:",
    "debug": "4.4.3",
    "purify-ts": "2.1.0",
    "react": "catalog:",
    "rxjs": "catalog:",
    "usb": "2.17.0",
    "yocto-spinner": "0.2.0",
    "zod": "catalog:",
    "@oxlint/binding-darwin-arm64": "1.51.0",
    "@oxlint/binding-darwin-x64": "1.51.0",
    "@oxlint/binding-linux-x64-gnu": "1.51.0",
    "@oxlint/binding-win32-x64-msvc": "1.51.0",
    "@types/debug": "4.1.12",
    "@types/node": "catalog:",
    "@types/w3c-web-usb": "^1.0.10",
    "bun-types": "1.3.12",
    "bunli": "0.9.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
