{
  "name": "@ledgerhq/wallet-cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "coverage": {
      "dependsOn": ["generate"],
      "outputs": ["{projectRoot}/coverage/**"]
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/.bunli/commands.gen.ts"]
    },
    "typecheck": {
      "dependsOn": ["generate"]
    },
    "test": {
      "dependsOn": ["generate"]
    },
    "build": {
      "cache": false
    },
    "prepare:npm": {
      "dependsOn": ["build"],
      "outputs": [
        "{projectRoot}/.npm-package/**",
        "{projectRoot}/bin/wallet-cli",
        "{projectRoot}/npm/*/.npm-package/**",
        "{projectRoot}/npm/*/bin/**"
      ],
      "cache": false
    },
    "pack:check": {
      "dependsOn": ["prepare:npm"],
      "cache": false
    },
    "smoke:npm": {
      "dependsOn": ["prepare:npm"],
      "cache": false
    }
  }
}
