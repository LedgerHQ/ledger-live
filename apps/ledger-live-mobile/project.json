{
  "name": "live-mobile",
  "targets": {
    "lint": {
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    },
    "lint:ci": {
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    },
    "lint:i18n": {
      "inputs": [
        "default",
        "^default",
        {
          "env": "CI_OS"
        }
      ]
    },
    "e2e:ci": {
      "dependsOn": [
        "^build",
        "@ledgerhq/dummy-live-app:build",
        "@ledgerhq/dummy-wallet-app:build",
        "@ledgerhq/dummy-ptx-app:build"
      ],
      "cache": false,
      "outputs": [
        "{projectRoot}/artifacts/**",
        "{workspaceRoot}/e2e/mobile/artifacts/**",
        "{projectRoot}/main.jsbundle",
        "{projectRoot}/main.jsbundle.minified",
        "{projectRoot}/build/**",
        "{projectRoot}/ios/build/**",
        "{projectRoot}/android/app/build/**"
      ],
      "inputs": [
        "default",
        "^default",
        "mobileEnv",
        "sharedEnv",
        {
          "env": "RUNNER_OS"
        }
      ]
    },
    "build": {
      "executor": "nx:noop"
    },
    "android:apk": {
      "outputs": [
        "{projectRoot}/android/app/build/generated/**",
        "{projectRoot}/android/app/build/intermediates/**"
      ],
      "inputs": [
        "default",
        "^default",
        "mobileEnv",
        "sharedEnv"
      ]
    },
    "ios:ci:adhoc": {
      "outputs": [
        "{projectRoot}/ios/build/**"
      ],
      "inputs": [
        "default",
        "^default",
        "mobileEnv",
        "sharedEnv"
      ]
    },
    "ios:local:ipa": {
      "outputs": [
        "{projectRoot}/ios/build/**"
      ],
      "inputs": [
        "default",
        "^default",
        "mobileEnv",
        "sharedEnv"
      ]
    }
  }
}