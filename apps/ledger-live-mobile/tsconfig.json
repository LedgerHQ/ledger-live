{
  "extends": "../../tsconfig.base",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "preserve",
    "allowJs": false,
    "checkJs": false,
    "jsx": "react-native",
    "lib": ["es2022", "DOM"],
    "types": ["node", "react", "jest", "jest-allure2-reporter/globals"],
    "noEmit": true,
    "target": "esnext",
    "paths": {
      "*": ["./*"],
      "~/*": ["./src/*"],
      "LLM/*": ["./src/mvvm/*"],
      "@tests/*": ["./__tests__/*"],
      "@mocks/*": ["./__mocks__/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": ["src/**/*", "e2e/**/*", "**/*.d.ts", "services/**/*"],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "**/*.js",
    "src/mocks/init.ts"
  ]
}
