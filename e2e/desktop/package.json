{
  "name": "ledger-live-desktop-e2e-tests",
  "version": "0.25.0",
  "private": true,
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxfmt . && oxlint . --fix",
    "typecheck": "tsc --noEmit --project tsconfig.json --customConditions node",
    "test:playwright": "playwright test --config=playwright.config.ts",
    "test:playwright:setup": "playwright install chromium",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure": "pnpm run allure:generate && pnpm run allure:open"
  },
  "dependencies": {
    "@ledgerhq/ledger-key-ring-protocol": "workspace:^",
    "@ledgerhq/live-cli": "workspace:^",
    "@ledgerhq/live-common": "workspace:^",
    "@ledgerhq/live-dmk-speculos": "workspace:^",
    "@ledgerhq/live-env": "workspace:^",
    "@ledgerhq/live-wallet": "workspace:^",
    "@ledgerhq/types-devices": "workspace:^",
    "@ledgerhq/types-live": "workspace:^",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "allure-js-commons": "catalog:",
    "allure-playwright": "catalog:",
    "axios": "catalog:",
    "bignumber.js": "9.1.2",
    "dotenv": "^16.4.7",
    "invariant": "^2.2.4",
    "lodash": "^4.17.21",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@types/invariant": "2.2.37",
    "@types/lodash": "4.17.16",
    "electron": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:"
  },
  "optionalDependencies": {
    "@oxlint/binding-darwin-arm64": "1.51.0",
    "@oxlint/binding-darwin-x64": "1.51.0",
    "@oxlint/binding-linux-x64-gnu": "1.51.0",
    "@oxlint/binding-win32-x64-msvc": "1.51.0"
  }
}
