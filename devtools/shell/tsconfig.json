{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleSuffixes": [".web", ""],
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["jest"]
  },
  "include": ["src/**/*", "jest.setup.ts", "jest/**/*"],
  "exclude": ["node_modules"]
}
