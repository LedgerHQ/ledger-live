{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "jest/*": ["./jest/*"],
      "jest/render.native": ["./jest/render/index.native.tsx"]
    },
    "lib": ["ES2024", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleSuffixes": [".web", ""],
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["jest"]
  },
  "include": ["src/**/*", "jest.setup.ts", "jest/**/*", "**/*.d.ts"],
  "exclude": ["node_modules", "jest/setup.native.ts"]
}
